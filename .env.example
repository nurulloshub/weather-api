# Weather API key
WEATHER_API_KEY=your_api_key_here

# Redis connection (default: localhost)
REDIS_URL=redis://localhost:6379/0 

# Cache expary (12 hours)
CACHE_EXPIRY_SECONDS=43200

# Rate limiting
RATE_LIMIT=100 per hour 
DEFAULT_RATE_LIMIT=100 per hour

# Flask settings

FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000



